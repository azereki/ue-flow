{
  "name": "@ue-flow/renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node -e \"require('fs').copyFileSync('dist/ue-flow.iife.js','../python/ue_flow/assets/ue-flow.iife.js')\"",
    "preview": "vite preview",
    "build:pages": "vite build --config vite.config.pages.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@xyflow/react": "^12",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "geist": "^1.7.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7",
    "typescript-eslint": "^8.57.2",
    "vite": "^6",
    "vitest": "^3"
  }
}
